{
  "name": "vianna",
  "private": true,
  "version": "0.0.12",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:desktop": "vite build --base ./ --outDir dist-electron",
    "desktop": "electron .",
    "appimage": "npm run build:desktop && electron-builder --linux AppImage",
    "preview": "vite preview",
    "test": "node --test",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix"
  },
  "build": {
    "appId": "es.vianna.app",
    "productName": "VIANNA",
    "files": [
      "dist-electron/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Science",
      "icon": "electron/assets/icon.png"
    }
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "@reduxjs/toolkit": "^2.6.1",
    "antd": "^5.24.6",
    "arquero": "^8.0.1",
    "d3": "^7.9.0",
    "formik": "^2.4.6",
    "jstat": "^1.9.6",
    "ml-pca": "^4.1.1",
    "papaparse": "^5.5.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-dropzone": "^14.3.8",
    "react-grid-layout": "^1.5.1",
    "react-redux": "^9.2.0",
    "react-resizable": "^3.0.5",
    "react-router-dom": "^7.4.1",
    "redux-state-sync": "^3.1.4",
    "simple-statistics": "^7.8.8"
  },
  "devDependencies": {
    "@babel/eslint-parser": "^7.28.5",
    "@eslint/js": "^9.39.2",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react-swc": "^3.8.0",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "eslint-plugin-unused-imports": "^4.3.0",
    "globals": "^15.15.0",
    "vite": "^6.2.0"
  }
}
